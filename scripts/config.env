#!/bin/bash
# Tunable defaults for the validation phase scripts.
# Sourced by each phase script; pre-existing environment values take precedence.

# P2P benchmark
P2P_BUFFER_SIZE="${P2P_BUFFER_SIZE:-16MiB}"

# Stress test
STRESS_BASE_PORT="${STRESS_BASE_PORT:-8000}"
STRESS_REVISION="${STRESS_REVISION:-v2026.1}"
# Comma-separated list of models; each entry is name:org.
STRESS_MODELS="${STRESS_MODELS:-Llama-3.1-8B-Instruct:meta-llama,Qwen2.5-0.5B-Instruct:Qwen}"
# Comma-separated list of triples; each entry is in_len:out_len:concurrency.
STRESS_FIXED_TRIPLES="${STRESS_FIXED_TRIPLES:-1024:1024:128,2048:1024:64,4096:1024:32,6144:1024:16,12288:1024:8,31744:1024:1}"

# Service-readiness wait (used by run_stress.sh check_models_up)
SERVE_READY_MAX_ATTEMPTS="${SERVE_READY_MAX_ATTEMPTS:-30}"
SERVE_READY_INTERVAL="${SERVE_READY_INTERVAL:-60}"

# Sensor monitor (used by lib/sensor_monitor.py via --interval)
SENSOR_POLL_INTERVAL="${SENSOR_POLL_INTERVAL:-1}"
